# ─── Banco de Dados ────────────────────────────────────────────────────────────
# LOCAL (SQLite - desenvolvimento): deixe DATABASE_URL vazio ou não defina
# PRODUÇÃO (PostgreSQL - Railway):  postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# ─── Segurança ────────────────────────────────────────────────────────────────
# PRODUÇÃO: gere um segredo forte → node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=tecfag-secret-local-dev

# ─── Ambiente ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── URLs Cross-Domain (Vercel ↔ Railway) ─────────────────────────────────────
# RAILWAY (backend): URL do frontend na Vercel — usada pelo CORS para permitir a origem
# Ex: https://fagner-tecfag.vercel.app
FRONTEND_URL=

# VERCEL (frontend/build): URL do backend no Railway — injetada no build pelo Vite
# Definir no painel da Vercel em: Project → Settings → Environment Variables
# Ex: https://tecfag-ia-faggner.up.railway.app
VITE_API_URL=

# ─── Gemini AI ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── RD Station Conversas (Tallos) ───────────────────────────────────────────
# Obter em: RD Conversas → Apps e Integrações → API
RD_CONVERSAS_TOKEN=
# URL base da API (padrão oficial)
RD_CONVERSAS_API_URL=https://api.tallos.com.br
# Nome exato do chip de WhatsApp cadastrado no RD Conversas
RD_CONVERSAS_INTEGRATION=
# Token secreto para validar webhooks recebidos do RD Conversas
RD_CONVERSAS_WEBHOOK_TOKEN=

# ─── Whitelist de teste ───────────────────────────────────────────────────────
# Números separados por vírgula, somente dígitos (E.164 sem o +)
# Deixar vazio para atender todos
RD_TEST_WHITELIST=

# ─── VTEX API (Autenticação para Frete + Checkout) ────────────────────────────
# Gerar em: Admin VTEX → Configurações da conta → Chaves de aplicação
VTEX_APP_KEY=vtexappkey-tecfag-XXXXXX
VTEX_APP_TOKEN=
VTEX_ACCOUNT_NAME=tecfag
